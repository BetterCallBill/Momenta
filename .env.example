# === Database ===
# Option A: Docker Postgres (recommended for local dev)
DATABASE_URL="postgresql://momenta:momenta@localhost:5432/momenta?schema=public"

# Option B: SQLite (simpler, some limitations with array fields)
# DATABASE_URL="file:./dev.db"

# Option C: Neon / Supabase (production)
# DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# === Site ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# === Stripe ===
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# === WeChat Web OAuth ===
# Get these from https://open.weixin.qq.com → Website Application (网站应用)
# Leave blank in local dev to use the built-in mock login endpoint instead.
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
# Secret used to sign the WeChat session JWT — use a long random string in prod
WECHAT_SESSION_SECRET="change-me-to-a-long-random-string"

# === Gmail OAuth 2.0 (confirmation emails) ===
# Set up at: https://console.cloud.google.com → APIs & Services → Credentials
# 1. Create an OAuth 2.0 Client ID (Desktop app)
# 2. Obtain a refresh token via the OAuth 2.0 Playground (https://developers.google.com/oauthplayground)
#    - In settings, check "Use your own OAuth credentials" and enter your client ID + secret
#    - Authorise scope: https://mail.google.com/
#    - Exchange the authorisation code for a refresh token
GMAIL_USER="you@gmail.com"
GMAIL_OAUTH_CLIENT_ID="263425975470-iitivud4b85ti3jha276esuh0qd2ag4i.apps.googleusercontent.com"
GMAIL_OAUTH_CLIENT_SECRET="GOCSPX-..."
GMAIL_OAUTH_REFRESH_TOKEN=""
